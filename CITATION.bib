  version = {6.0},
  doi = {10.5281/zenodo.XXXXXX}, % To be assigned upon publication
  keywords = {quantum chemistry, nuclear-electronic orbital, NEO, constrained NEO, cNEO, quantum computing, variational quantum eigensolver, VQE, quantum algorithms},
  abstract = {
    A specialized Julia package for quantum chemistry calculations using Nuclear-Electronic Orbital (NEO) methods. 
    Implements sparse Quantum Eigensolver with constrained Nuclear-Electronic Orbital (cNEO) support for quantum 
    computing applications, treating selected nuclei (usually protons) quantum mechanically alongside electrons. 
    Features include complete cNEO-QEE integration pipeline, Clean Code implementation with comprehensive testing, 
    and export capabilities for quantum computing frameworks (OpenFermion, Qiskit, Cirq).
  },
  note = {Software package with integrated constrained NEO and quantum eigensolver methods}
}

