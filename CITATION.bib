@software{SparseQEEcNEO,
  title = {SparseQEEcNEO.jl: Sparse Quantum Eigensolver with constrained Nuclear-Electronic Orbital support},
  author = {Federico Zahariev and Jacson J. Hayes and contributors},
  year = {2024},
